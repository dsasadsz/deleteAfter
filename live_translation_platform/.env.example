APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=text
ENABLE_OPENAPI_DOCS=true
ENABLE_DEBUG_ENDPOINTS=true
ENABLE_LOAD_TEST_ENDPOINTS=false
# Production C# site origin and public Python service host examples.
ALLOWED_ORIGINS=https://csharp-site.example.com
TRUSTED_HOSTS=python-service.example.com
WORKER_SHUTDOWN_TIMEOUT_SECONDS=30

# Docker production-like compose uses safe production defaults, but these
# values can be overridden from a private .env or shell environment.
# For local/staging mock load tests, prefer:
# docker compose -f docker-compose.prod.yml -f docker-compose.loadtest.yml up -d --build
# APP_ENV=development
# ENABLE_LOAD_TEST_ENDPOINTS=true
# TTS_LOAD_TEST_BYPASS_RATE_LIMIT=true

# Database
# SQLite is for local development and demos.
DATABASE_URL=sqlite:///./dev.db
# Docker Compose PostgreSQL uses service hostname "postgres", never localhost.
POSTGRES_DB=live_translation
POSTGRES_USER=live_translation
POSTGRES_PASSWORD=change-me
COMPOSE_DATABASE_URL=postgresql+psycopg://live_translation:change-me@postgres:5432/live_translation
# Local non-Docker PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://live_translation:change-me@localhost:5432/live_translation
# Docker Compose app containers receive:
# DATABASE_URL=postgresql+psycopg://live_translation:change-me@postgres:5432/live_translation
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO=false
POSTGRES_REQUIRED_IN_PRODUCTION=true
SQLITE_ALLOWED_IN_PRODUCTION=false

# Redis / Scaling
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
COMPOSE_REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=live_translation
REDIS_REQUIRED_IN_PRODUCTION=false
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_HEALTH_TIMEOUT_SECONDS=1
# Shared fixed-window rate limits across workers when Redis is enabled.
REDIS_RATE_LIMIT_ENABLED=false
REDIS_RATE_LIMIT_FAIL_CLOSED=false
REDIS_PUBSUB_ENABLED=false
REDIS_PUBSUB_FAIL_CLOSED=false
REDIS_TTS_CACHE_ENABLED=false

LESSON_MODE=mock

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
