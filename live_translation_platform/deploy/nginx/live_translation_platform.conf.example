# Example Nginx HTTPS/WSS reverse proxy for live_translation_platform.
# Replace python-service.example.com and certificate paths with your real values.
# WSS requires TLS certificate termination at the reverse proxy.
# Production must keep ENABLE_LOAD_TEST_ENDPOINTS=false and should expose only
# the documented /api/, /ws/, /static/, and browser routes.
# If multiple app workers serve teacher audio ingest, configure sticky routing
# for lesson WebSockets or keep audio ingest on a single worker.

upstream live_translation_platform {
    server app:8000;
}

server {
    listen 80;
    server_name python-service.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name python-service.example.com;

    ssl_certificate /etc/letsencrypt/live/python-service.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/python-service.example.com/privkey.pem;

    client_max_body_size 25m;

    location /ws/ {
        proxy_pass http://live_translation_platform;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
    }

    location /api/ {
        proxy_pass http://live_translation_platform;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    location /static/ {
        proxy_pass http://live_translation_platform;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        expires 1h;
    }

    location / {
        proxy_pass http://live_translation_platform;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
